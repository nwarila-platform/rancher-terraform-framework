# Tenant-owned workload input only.
# The platform deploy runner injects auth, identity, caps, quota, and backend
# settings out-of-band with TF_VAR_* and -backend-config. Do not put Rancher
# tokens, kubeconfigs, cluster IDs, project names, or backend credentials here.
# Omitting chart_path uses the built-in charts/platform-workload chart.

all_workloads = [
  {
    key = "hello"

    ingress = {
      host = "hello.example.invalid"
    }

    # ghcr.io/stefanprodan/podinfo:6.9.2 was verified as UID 100 and serving
    # HTTP on port 9898 with a read-only root filesystem, no new privileges,
    # and all Linux capabilities dropped. Mirror it under an approved NWarila
    # registry path before production image-verification policy is enforced.
    values = {
      containerPort = 9898
      image = {
        repository = "ghcr.io/stefanprodan/podinfo"
        digest     = "sha256:cab90e04829cdae73199a8402882a4e3ccaf251b8a0d50bdefede0ab3f6371e7"
      }
    }
  }
]
