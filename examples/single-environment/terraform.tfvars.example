# Smallest possible valid input to terraform-framework-template.
# Copy to `terraform.tfvars` (gitignored) and run `terraform apply`.

environment_prefix = "demo"
global_tag         = "framework-example-quickstart"

all_environments = [
  {
    name  = "hello"
    owner = "you@example.com"
    tier  = "dev"
  }
]
