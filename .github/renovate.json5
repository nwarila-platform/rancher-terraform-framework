{
  // Schema for editor validation. Update only when intentionally adopting a new schema.
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  // Renovate config for NWarila/terraform-framework-template - the canonical
  // baseline for every Terraform-framework consumer in the portfolio. This
  // file is the single source of truth for Renovate behavior across framework
  // repos; consumers extend it via
  // `extends: ["github>NWarila/terraform-framework-template//.github/renovate.json5"]` (see org
  // ADR-0004 in NWarila/.github for the per-template-baseline model).
  //
  // Rules in this file:
  //   - Pin third-party GitHub Actions to commit SHAs (matches the OPA
  //     repo_hygiene package's enforcement and org ADR-0004's
  //     SHA-pin retention check).
  //   - Pin Terraform and provider versions exactly.
  //   - Track explicit `# renovate:` annotations in workflow comments
  //     for tool versions (Terraform CLI, terraform-docs, OPA, etc.).

  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],

  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,

  // Supply-chain quarantine. No update lands sooner than 7 days after the
  // upstream release was published. Combined with `internalChecksFilter:
  // "strict"`, a release whose timestamp Renovate cannot resolve is treated
  // as failing the age check (rather than silently passing). Catches the
  // common compromised-package window where a malicious release gets yanked
  // within hours/days of publication.
  //
  // No vulnerability-alert carve-out is configured here; if a CVE-driven
  // immediate-bump policy becomes necessary, add
  // `vulnerabilityAlerts: { enabled: true, minimumReleaseAge: "0 days" }`
  // and record the carve-out in a superseding ADR.
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",

  "enabledManagers": [
    "github-actions",
    "terraform",
    "pre-commit",
    "pip_requirements",
    "custom.regex"
  ],

  "customManagers": [
    {
      // Match `# renovate: datasource=...` annotations followed by a
      // value: "..." or value: '...' assignment. Catches Terraform/
      // terraform-docs/OPA versions in workflow inputs and shell scripts.
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.ya?ml$/",
        "/^tools/.*\\.sh$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: packageName=(?<packageName>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?\\s+\\w+(?:_VERSION)?:\\s*\"(?<currentValue>[^\"]+)\"",
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: packageName=(?<packageName>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?\\s+\\w+_VERSION=\"(?<currentValue>[^\"]+)\"",
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: packageName=(?<packageName>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?\\s+pip install --no-cache-dir (?<depName2>[a-zA-Z0-9-._]+)==(?<currentValue>[^\\s]+)"
      ]
    },
    {
      // Track SHA body inputs that must move with reusable workflow `uses:`
      // pins. Renovate's git-refs datasource treats the branch name as
      // currentValue and the checked-in 40-char SHA as currentDigest.
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.ya?ml$/"
      ],
      "datasourceTemplate": "git-refs",
      "versioningTemplate": "loose",
      "matchStrings": [
        "# renovate: depName=(?<depName>[^\\s]+) packageName=(?<packageName>[^\\s]+) currentValue=(?<currentValue>[^\\s]+)\\s+(?:template_ref|framework_ref|source-ref):\\s*(?<currentDigest>[0-9a-f]{40})"
      ]
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    },
    {
      "matchManagers": ["terraform"],
      "rangeStrategy": "pin",
      "semanticCommitType": "deps",
      "semanticCommitScope": "deps"
    },
    {
      "matchDepNames": ["hashicorp/terraform"],
      "groupName": "Terraform CLI",
      "semanticCommitType": "deps",
      "semanticCommitScope": "deps"
    },
    {
      "matchDepNames": ["actions/setup-python"],
      "groupName": "actions/setup-python",
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    },
    {
      "matchDepNames": ["actions/upload-artifact"],
      "groupName": "actions/upload-artifact",
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    },
    {
      // Bumps to first-party workflow/control-plane repositories are grouped
      // and reviewed by the maintainer.
      "matchDepNames": [
        "NWarila/.github",
        "NWarila/drift-gate",
        "NWarila/terraform-framework-template"
      ],
      "groupName": "first-party workflow pins",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "automerge": false
    }
  ]
}
